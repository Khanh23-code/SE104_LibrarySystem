<Window x:Class="THUVIENZ.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login System" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Images/bg.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Border Width="1050" Height="620" CornerRadius="35" Background="#30FFFFFF">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="35,0,0,35" Background="#40FFFFFF">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                        <Ellipse Width="180" Height="180" Stroke="White" StrokeThickness="3">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="pack://application:,,,/Images/phai.png" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="Welcome to your&#x0a;Library&#x0a;Management System" 
                                   FontSize="24" FontWeight="Bold" Foreground="White" 
                                   TextAlignment="Center" Margin="0,30,0,0" LineHeight="36"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="35">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
                        <TextBlock Text="📚 L i b r i x" FontSize="36" FontWeight="Bold" Foreground="#4285F4" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="LOGIN" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                        <TextBlock Text="User ID" FontSize="18" FontWeight="SemiBold" Margin="10,0,0,5"/>
                        <Border Background="#EAEAEA" CornerRadius="25" Height="55" Margin="0,0,0,20">
                            <TextBox Background="Transparent" BorderThickness="0" FontSize="18" VerticalContentAlignment="Center" Padding="20,0" Foreground="Black"/>
                        </Border>

                        <TextBlock Text="Password" FontSize="18" FontWeight="SemiBold" Margin="10,0,0,5"/>
                        <Border Background="#EAEAEA" CornerRadius="25" Height="55" Margin="0,0,0,10">
                            <PasswordBox Background="Transparent" BorderThickness="0" FontSize="18" VerticalContentAlignment="Center" Padding="20,0"/>
                        </Border>

                        <TextBlock Text="Forgot Password / User ID" FontSize="14" HorizontalAlignment="Center" Foreground="#555" Margin="0,10,0,30" Cursor="Hand"/>

                        <Button Content="Submit" Click="BtnSubmit_Click" Foreground="White" FontSize="22" FontWeight="Bold" Width="200" Height="60" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#0CE346"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="30">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>